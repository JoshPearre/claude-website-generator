# Firecrawl API key — used by the harvest workflow (harvest/firecrawl-workflow.md)
# to scrape JS-rendered prompt-library sites. Free tier available: https://firecrawl.dev
FIRECRAWL_API_KEY=

# Image generation uses the connected Canva MCP server, which authenticates with a
# one-time browser login (a free Canva account). There is NO key to set here.

# The 21st.dev Magic MCP (optional component generator) is configured in your
# Claude Code MCP settings, not in this file. See README.md.

# ─── Image API (Step 5) — GENERATION-TIME ONLY, never commit real values ───
# Used only while the skill runs, to search for and DOWNLOAD images into the
# generated project's public/. The key calls api.pexels.com / api.unsplash.com
# at generation time and is NEVER written into the generated site or its bundle.
# Do NOT prefix with VITE_ / NEXT_PUBLIC_ (that would leak it into client code).
# Provide EITHER key. Pexels is the default; if both are set, Pexels is used;
# if neither is set, Step 5 falls back to Neurascapes → Canva → placeholder.
#
# Pexels — recommended default (free, generous limits, no required attribution)
#   Get one: https://www.pexels.com/api/
PEXELS_API_KEY=

# Unsplash — alternative (requires visible attribution + a download-trigger call)
#   Get one: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
